NODE_ENV=development
NEXT_PUBLIC_SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_me
STRIPE_SECRET_KEY=replace_me
STRIPE_RESTRICTED_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
APIFY_TOKEN=replace_me
APIFY_BAT_ACTOR_ID=replace_me
APIFY_CARSANDBIDS_ACTOR_ID=replace_me
APIFY_AUTOSCOUT24_ACTOR_ID=replace_me
APIFY_CLASSICCARS_ACTOR_ID=replace_me

# ── AI Listing Rewriter ───────────────────────────────────────────────
# Feature flag — set to "true" to activate the editorial hook on the
# listing detail page. Defaults to disabled so production can ship dark.
LISTING_REWRITER_ENABLED=false

# Gemini API key used by the listing rewriter and other AI features.
GEMINI_API_KEY=
# Optional override for Gemini model id. Defaults to gemini-2.5-flash.
GEMINI_MODEL=
# Advisor-specific model overrides (used by the chat orchestrator + premium
# web_search / fetch_url tools). Defaults shown.
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# ── Advisor (Personal Advisor / Pistons) ─────────────────────────────
# HMAC secret for signing the anonymous-session cookie used by unauth
# advisor chats. MUST be at least 32 characters (random bytes, base64url
# or hex). Rotating invalidates all anonymous sessions.
ADVISOR_ANON_SECRET=CHANGE_ME_to_32plus_random_chars

# Feature flag for the advisor rollout. Accepted values:
#   internal   — only user ids listed in ADVISOR_INTERNAL_USER_IDS
#   free_beta  — any signed-in FREE or PRO user (cohort-gated at the route)
#   full       — everyone (signed-in and anonymous)
# See docs/advisor/rollout.md for the 5-stage rollout plan.
ADVISOR_ENABLED=internal

# Comma-separated list of Supabase user ids allowed when ADVISOR_ENABLED=internal.
ADVISOR_INTERNAL_USER_IDS=

# ── Meta Pixel / Conversions API ─────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=1497731501724687
META_CAPI_ACCESS_TOKEN=                # Server-side only — NEVER prefix with NEXT_PUBLIC_
META_CAPI_TEST_EVENT_CODE=             # Optional — from Events Manager → Test Events tab
META_DOMAIN_VERIFICATION_TOKEN=6kn33pdk2lzvaj08jowe39llb1rzqx
